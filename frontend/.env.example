# URL of the backend API.
# Local dev: leave this BLANK. vite.config.js proxies /api and /uploads
#   requests through to http://localhost:8000 on your machine, so relative
#   requests work correctly even when you access the dev server from another
#   device or a tunnel (e.g. test.heinh.dev) — "http://localhost:8000" would
#   otherwise mean that device's own localhost, not this machine's.
# Production (Vercel): required — set to your backend's real public URL,
#   e.g. https://api.yourdomain.com. There's no dev proxy in a static build.
VITE_API_URL=
