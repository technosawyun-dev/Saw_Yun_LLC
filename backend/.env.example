# Database
# Local dev (docker-compose.yml): postgresql://sawyun:sawyun_password@postgres:5432/sawyun
# Production (docker-compose.prod.yml): postgresql://USER:PASSWORD@postgres:5432/DBNAME
DATABASE_URL=postgresql://sawyun:sawyun_password@localhost:5432/sawyun

# Postgres container credentials (used by docker-compose.prod.yml)
POSTGRES_USER=sawyun
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=sawyun
POSTGRES_HOST_PORT=15432

# Backend port (used by docker-compose.prod.yml, bound to 127.0.0.1 only)
BACKEND_PORT=8000

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Or run: python setup.py
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# CORS
# Comma-separated list of allowed frontend origins
# Local dev: http://localhost:5173
# Production: https://your-site.vercel.app (and any custom domain)
CORS_ORIGINS=http://localhost:5173

# First admin (one-time setup)
# Used only on first startup to seed the admin account.
# After setup, change your password via the admin panel.
# Or run: python setup.py
FIRST_ADMIN_EMAIL=you@yourdomain.com
FIRST_ADMIN_PASSWORD=choose-a-strong-password

# Email notifications (optional)
# When a visitor submits the contact form, it's always saved and viewable
# under /admin → Messages. Filling in MAILTRAP_API_TOKEN + NOTIFY_TO_EMAIL
# below also sends you an email the moment it comes in. Leave
# MAILTRAP_API_TOKEN blank to skip email entirely — nothing else changes.
#
# Sent via the Mailtrap Sending API (an HTTPS call), not raw SMTP — most VPS
# providers block outbound SMTP ports by default, so SMTP silently fails in
# production even when it works fine locally.
#   1. Sign up at https://mailtrap.io, verify a sending domain (or use their
#      shared test domain while developing).
#   2. Get your API token from Email Sending → Sending Domains → your domain
#      → API tokens (or Settings → API Tokens).
#   3. Set EMAIL_FROM to an address on your verified sending domain.
EMAIL_ENABLED=true
MAILTRAP_API_TOKEN=
EMAIL_FROM=noreply@sawyun.com
EMAIL_FROM_NAME=Saw Yun LLC
NOTIFY_TO_EMAIL=
